{
  "version": "1.0.2",
  "systemName": "CartGenie",
  "architecture": "Trust-Layered Multi-Agent Customer Support Architecture",
  "platformType": "generic_indian_ecommerce",
  "policySources": [
    "Flipkart",
    "Myntra",
    "Meesho"
  ],
  "description": "Generic Indian e-commerce policy rules for CartGenie multi-agent customer support system. LLM agents understand the query, but policy decisions must be made by ruleEngine.js using this rules.json and order data.",

  "thresholds": {
    "highConfidence": 0.75,
    "lowConfidence": 0.5,
    "highValueOrder": 50000,
    "veryHighValueOrder": 200000,
    "maxRepeatedFailures": 3
  },

  "supportedIntents": [
    "cancel_order",
    "return_order",
    "replace_order",
    "refund_status",
    "refund_policy",
    "exchange_order",
    "track_order",
    "order_status",
    "delivery_policy",
    "delivery_issue",
    "payment_issue",
    "missing_item",
    "wrong_item",
    "damaged_item",
    "return_policy",
    "replacement_policy",
    "cancellation_policy",
    "human_support",
    "order_reference_only",
    "greeting",
    "non_commerce_request",
    "unsafe_request",
    "general_support"
  ],

  "statuses": {
    "cancellable": [
      "placed",
      "confirmed",
      "processing"
    ],
    "nonCancellable": [
      "dispatched",
      "shipped",
      "out_for_delivery",
      "delivered",
      "cancelled",
      "return_picked",
      "return_received",
      "quality_check_passed",
      "quality_check_failed",
      "refund_initiated",
      "refund_completed",
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ],
    "returnable": [
      "delivered"
    ],
    "trackable": [
      "placed",
      "confirmed",
      "processing",
      "dispatched",
      "shipped",
      "out_for_delivery",
      "delivered",
      "cancelled",
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ],
    "refundProcessStatuses": [
      "cancelled",
      "return_picked",
      "return_received",
      "quality_check_passed",
      "refund_initiated",
      "refund_completed"
    ],
    "failedDeliveryStatuses": [
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ]
  },

  "cancellation": {
    "description": "Cancellation is allowed only before dispatch/shipment. Once dispatched, shipped, out for delivery, delivered, returned, or refund process has started, cancellation is blocked.",
    "allowedStatuses": [
      "placed",
      "confirmed",
      "processing"
    ],
    "blockedStatuses": [
      "dispatched",
      "shipped",
      "out_for_delivery",
      "delivered",
      "cancelled",
      "return_picked",
      "return_received",
      "quality_check_passed",
      "quality_check_failed",
      "refund_initiated",
      "refund_completed",
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ],
    "refundRules": {
      "prepaidCancellationRefund": true,
      "refundToOriginalPaymentSource": true,
      "codRefundRequired": false,
      "sellerCancellationFullRefund": true,
      "platformCancellationFullRefund": true,
      "offerReversalOnCancellation": true
    },
    "decisionCodes": {
      "allowed": "cancel_allowed",
      "allowedWithRefund": "cancel_allowed_refund_initiated",
      "blockedDispatched": "cancel_blocked_dispatched",
      "blockedShipped": "cancel_blocked_shipped",
      "blockedOutForDelivery": "cancel_blocked_out_for_delivery",
      "blockedDelivered": "cancel_blocked_delivered",
      "alreadyCancelled": "cancel_already_done",
      "blockedAfterReturnStarted": "cancel_blocked_return_process_started",
      "requiresEscalation": "cancel_requires_escalation"
    }
  },

  "return": {
    "description": "Return is allowed only if the product is returnable, request is inside the return window, product is not in a blocked category, and pickup/quality conditions are satisfied.",
    "defaultReturnWindowDays": 7,
    "categoryReturnWindows": {
      "fashion": 10,
      "home": 7,
      "furniture": 10,
      "electronics": 7,
      "smartphone": 0,
      "large_appliance": 10,
      "grocery_perishable": 2,
      "grocery_regular": 7,
      "books": 7,
      "sports": 7,
      "medicine": 2,
      "refurbished": 7,
      "personal_care": 0,
      "hygiene": 0,
      "innerwear": 0,
      "altered_product": 0
    },
    "blockedCategories": [
      "innerwear",
      "personal_care",
      "hygiene",
      "perishable",
      "intimate_wear",
      "sanitary_product",
      "medicine_prescription",
      "altered_product"
    ],
    "returnOnlyForIssueCategories": {
      "non_returnable_exception_issues": [
        "damaged_product",
        "wrong_product",
        "missing_item",
        "incomplete_product",
        "expired_product"
      ]
    },
    "qualityCheckRequired": true,
    "requiredConditions": [
      "correct_product",
      "complete_product",
      "unused_product",
      "undamaged_product",
      "original_packaging",
      "tags_intact",
      "accessories_present"
    ],
    "deviceReturnConditions": [
      "device_formatted",
      "screen_lock_removed",
      "icloud_removed_if_apple"
    ],
    "decisionCodes": {
      "allowed": "return_allowed",
      "blockedNotDelivered": "return_blocked_not_delivered",
      "blockedWindowExpired": "return_blocked_window_expired",
      "blockedNonReturnable": "return_blocked_non_returnable",
      "qualityCheckRequired": "return_quality_check_required",
      "blockedQualityCheckFailed": "return_blocked_quality_check_failed",
      "blockedMissingAccessories": "return_blocked_missing_accessories",
      "blockedWrongProduct": "return_blocked_wrong_product",
      "blockedAlteredProduct": "return_blocked_altered_product",
      "requiresEscalation": "return_requires_escalation"
    }
  },

  "replacement": {
    "description": "Replacement is allowed for defective, damaged, wrong, missing, incomplete, technical issue, or dead-on-arrival cases within the allowed replacement window. Sensitive categories such as smartphones, electronics, and large appliances may require brand verification, DOA certificate, or unboxing proof.",
    "defaultReplacementWindowDays": 7,
    "categoryReplacementWindows": {
      "fashion": 10,
      "home": 7,
      "furniture": 10,
      "electronics": 7,
      "smartphone": 7,
      "large_appliance": 10,
      "books": 7,
      "sports": 7,
      "toys": 7,
      "stationery": 7,
      "refurbished": 7
    },
    "allowedIssueTypes": [
      "defective_product",
      "damaged_product",
      "wrong_product",
      "missing_item",
      "incomplete_product",
      "technical_issue",
      "dead_on_arrival"
    ],
    "replacementOnlyCategories": [
      "smartphone",
      "electronics",
      "large_appliance",
      "refurbished",
      "books",
      "sports",
      "toys",
      "stationery"
    ],
    "brandVerificationCategories": [
      "smartphone",
      "electronics",
      "large_appliance"
    ],
    "requiresUnboxingProofFor": [
      "smartphone_damage",
      "electronics_damage",
      "large_appliance_damage",
      "wrong_product",
      "missing_item",
      "damaged_product",
      "dead_on_arrival"
    ],
    "requiresDOACertificateFor": [
      "smartphone",
      "electronics"
    ],
    "onlyOneReplacementAllowed": true,
    "decisionCodes": {
      "allowed": "replacement_allowed",
      "replacementOnly": "replacement_only",
      "requiresBrandVerification": "replacement_requires_brand_verification",
      "requiresUnboxingProof": "replacement_requires_unboxing_proof",
      "requiresDOACertificate": "replacement_requires_doa_certificate",
      "blockedWindowExpired": "replacement_blocked_window_expired",
      "blockedAlreadyReplaced": "replacement_blocked_already_replaced",
      "blockedIssueNotEligible": "replacement_blocked_issue_not_eligible",
      "requiresEscalation": "replacement_requires_escalation"
    }
  },

  "refund": {
    "description": "Refund is processed after successful cancellation or after returned product is picked up, received, and verified. Refund usually goes to the original payment source. COD refunds may require bank details.",
    "refundAfterCancellation": true,
    "refundAfterReturnReceived": true,
    "refundAfterQualityCheck": true,
    "refundToOriginalPaymentSource": true,
    "codRequiresBankDetails": true,
    "offerReversalOnCancellation": true,
    "standardTimelineBusinessDays": "3-7",
    "walletTimelineBusinessDays": "0-2",
    "cardRefundTimelineBusinessDays": "7-10",
    "decisionCodes": {
      "initiated": "refund_initiated",
      "completed": "refund_completed",
      "pendingPickup": "refund_pending_return_pickup",
      "pendingReturnReceived": "refund_pending_return_received",
      "pendingQualityCheck": "refund_pending_quality_check",
      "pendingBankDetails": "refund_pending_bank_details",
      "originalPaymentSource": "refund_original_payment_source",
      "blockedPolicyViolation": "refund_blocked_policy_violation",
      "discrepancyEscalate": "refund_discrepancy_escalate"
    }
  },

  "exchange": {
    "description": "Exchange is allowed only when product is exchangeable, stock is available, address is serviceable, request is within exchange window, and quality check passes.",
    "defaultExchangeWindowDays": 7,
    "categoryExchangeWindows": {
      "fashion": 10,
      "home": 7,
      "furniture": 10,
      "electronics": 0,
      "smartphone": 0,
      "large_appliance": 0,
      "books": 0,
      "sports": 0,
      "grocery_regular": 0,
      "grocery_perishable": 0
    },
    "stockRequired": true,
    "serviceableAddressRequired": true,
    "qualityCheckRequired": true,
    "onlyOneExchangeAllowed": true,
    "notAllowedReasons": [
      "customer_not_interested",
      "quality_expectation_issue",
      "fraud_risk",
      "wrong_product_returned"
    ],
    "decisionCodes": {
      "allowed": "exchange_allowed",
      "blockedNotExchangeable": "exchange_blocked_not_exchangeable",
      "blockedStockUnavailable": "exchange_blocked_stock_unavailable",
      "blockedAddressNotServiceable": "exchange_blocked_address_not_serviceable",
      "blockedWindowExpired": "exchange_blocked_window_expired",
      "convertedToReturn": "exchange_converted_to_return",
      "blockedAlreadyExchanged": "exchange_blocked_already_exchanged",
      "blockedReasonNotEligible": "exchange_blocked_reason_not_eligible"
    }
  },

  "payment": {
    "description": "Payment failure, double payment, refund mismatch, unsupported refund bank, COD limitation, high-value payment, and suspicious transaction cases should be verified or escalated.",
    "codMaxOrderValue": 50000,
    "panRequiredAbove": 200000,
    "supportedMethods": [
      "upi",
      "card",
      "netbanking",
      "wallet",
      "cod",
      "pay_later",
      "emi"
    ],
    "paymentConflictStatuses": [
      "failed",
      "double_charged",
      "refund_failed",
      "refund_not_received",
      "payment_pending_but_debited"
    ],
    "escalatePaymentConflicts": true,
    "escalateRefundDisputes": true,
    "requiresVerificationForHighValue": true,
    "decisionCodes": {
      "paymentIssueEscalate": "payment_issue_escalate",
      "refundDisputeEscalate": "refund_dispute_escalate",
      "bankDetailsRequired": "bank_details_required",
      "transactionUnderVerification": "transaction_under_verification",
      "codNotAvailable": "cod_not_available",
      "panVerificationRequired": "pan_verification_required",
      "paymentMethodSupported": "payment_method_supported"
    }
  },

  "delivery": {
    "description": "Tracking/status information is available once the order is placed and should clearly show whether the order is placed, confirmed, processing, dispatched, shipped, out for delivery, delivered, cancelled, failed, returned to origin, or lost in transit. Delivery delay, failed delivery, address not serviceable, returned to origin, or lost shipment may require escalation.",
    "trackingStatuses": [
      "placed",
      "confirmed",
      "processing",
      "dispatched",
      "shipped",
      "out_for_delivery",
      "delivered",
      "cancelled",
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ],
    "failedDeliveryStatuses": [
      "delivery_failed",
      "returned_to_origin",
      "lost_in_transit"
    ],
    "standardDeliveryTimelineDays": "3-7",
    "expressDeliveryTimelineDays": "1-3",
    "policyResponse": {
      "deliveryTimeline": "Most orders are delivered within 3-7 business days depending on location, seller, courier partner, and product category. To check an exact order status, the customer should share the order ID.",
      "trackingWithoutOrderId": "Delivery timeline depends on order status and location. Ask for the order ID to provide exact tracking details."
    },
    "decisionCodes": {
      "trackingAvailable": "tracking_available",
      "trackingNotAvailable": "tracking_not_available",
      "orderPlaced": "order_placed",
      "orderProcessing": "order_processing",
      "orderShipped": "order_shipped",
      "orderOutForDelivery": "order_out_for_delivery",
      "orderDelivered": "order_delivered",
      "deliveryDelayInfo": "delivery_delay_info",
      "deliveryFailedEscalate": "delivery_failed_escalate",
      "addressNotServiceable": "address_not_serviceable",
      "lostInTransitEscalate": "lost_in_transit_escalate",
      "returnedToOrigin": "returned_to_origin"
    }
  },

  "policyInfo": {
    "description": "General policy queries should be answered politely without creating escalation or failure count. Exact order-specific decisions still require order ID and rule-engine validation.",
    "delivery_policy": {
      "message": "Most orders are delivered within 3-7 business days depending on product type, seller, courier partner, and delivery location. For exact tracking, the customer should share the order ID."
    },
    "refund_policy": {
      "message": "Refunds are usually processed after cancellation confirmation or after return pickup, receiving, and quality check. Refunds generally go to the original payment source. Timelines may vary by payment method."
    },
    "return_policy": {
      "message": "Returns depend on product category, return window, item condition, pickup eligibility, and quality check. Some categories such as hygiene, innerwear, perishable, or altered products may be non-returnable except for valid issue-based exceptions."
    },
    "replacement_policy": {
      "message": "Replacement may be available for damaged, defective, wrong, missing, incomplete, technical issue, or dead-on-arrival cases within the allowed replacement window. Sensitive categories may require proof or brand verification."
    },
    "cancellation_policy": {
      "message": "Cancellation is usually allowed before dispatch or shipment. Once an order is shipped, out for delivery, or delivered, cancellation is blocked and the customer may need to check return or replacement eligibility after delivery."
    }
  },

  "guardrails": {
    "description": "These are used by the Input Guardrail Agent, Confidence Agent, and fallback routing before normal rule-engine processing.",
    "invalidQueryPatterns": [
      "empty_query",
      "only_symbols",
      "too_short",
      "random_gibberish"
    ],
    "promptInjectionPatterns": [
      "ignore previous instructions",
      "bypass rules",
      "forget policy",
      "act as admin",
      "approve my refund without checking",
      "override policy",
      "reveal system prompt",
      "show hidden instructions"
    ],
    "nonCommerceRequestExamples": [
      "tell me a joke",
      "write a shayari",
      "write a poem",
      "solve my homework",
      "write code",
      "weather",
      "news",
      "general knowledge"
    ],
    "greetingExamples": [
      "hello",
      "hi",
      "hey",
      "good morning",
      "good evening"
    ],
    "abusiveSignals": [
      "abuse",
      "threat",
      "extreme_anger"
    ],
    "decisionCodes": {
      "invalidQuery": "invalid_query",
      "promptInjectionDetected": "prompt_injection_detected",
      "abusiveCustomer": "abusive_customer_detected",
      "safeInput": "safe_input",
      "nonCommerceRequest": "non_commerce_request",
      "greetingDetected": "greeting_detected"
    }
  },

  "escalation": {
    "description": "Risky, unsafe, angry, payment-sensitive, fraud-risk, policy-conflict, repeated unresolved, or verification-heavy cases must be escalated to human support. Normal greetings, policy information, off-topic requests, and simple tracking should not be escalated.",
    "triggers": [
      "angry_customer",
      "abusive_customer",
      "high_value_order",
      "very_high_value_order",
      "payment_conflict",
      "refund_dispute",
      "policy_conflict",
      "fraud_risk",
      "missing_product_claim",
      "wrong_product_claim",
      "smartphone_doa_claim",
      "brand_verification_required",
      "unboxing_proof_required",
      "repeated_low_confidence",
      "order_status_unclear",
      "pan_verification_required",
      "prompt_injection_detected",
      "unsafe_input_detected",
      "customer_requested_human_support"
    ],
    "nonEscalatingInformationalDecisions": [
      "order_delivered",
      "order_in_transit",
      "order_shipped",
      "order_placed",
      "order_confirmed",
      "order_out_for_delivery",
      "order_not_dispatched",
      "tracking_info_available",
      "delivery_policy_info",
      "refund_policy_info",
      "return_policy_info",
      "replacement_policy_info",
      "cancellation_policy_info"
    ],
    "priorityMap": {
      "very_high_value_order": "CRITICAL",
      "pan_verification_required": "CRITICAL",
      "prompt_injection_detected": "CRITICAL",
      "unsafe_input_detected": "CRITICAL",
      "payment_conflict": "HIGH",
      "refund_dispute": "HIGH",
      "angry_customer": "HIGH",
      "abusive_customer": "HIGH",
      "fraud_risk": "HIGH",
      "smartphone_doa_claim": "HIGH",
      "customer_requested_human_support": "HIGH",
      "missing_product_claim": "MEDIUM",
      "wrong_product_claim": "MEDIUM",
      "policy_conflict": "MEDIUM",
      "brand_verification_required": "MEDIUM",
      "unboxing_proof_required": "MEDIUM",
      "repeated_low_confidence": "MEDIUM",
      "order_status_unclear": "MEDIUM",
      "high_value_order": "MEDIUM"
    },
    "decisionCodes": {
      "criticalPriority": "escalate_critical_priority",
      "highPriority": "escalate_high_priority",
      "paymentConflict": "escalate_payment_conflict",
      "policyConflict": "escalate_policy_conflict",
      "fraudRisk": "escalate_fraud_risk",
      "verificationRequired": "escalate_verification_required",
      "humanReview": "escalate_human_review"
    }
  },

  "responseTone": {
    "default": "polite_clear_professional",
    "angryCustomer": "empathetic_and_escalation_ready",
    "blockedPolicy": "clear_reason_with_next_step",
    "allowedAction": "positive_confirmation_with_next_step",
    "offTopic": "warm_boundary_redirect_to_order_support",
    "greeting": "friendly_short_and_order_support_oriented",
    "clarification": "helpful_and_specific_about_missing_detail"
  },

  "commonErrors": {
    "missingOrderId": "missing_order_id",
    "orderNotFound": "order_not_found",
    "unsupportedIntent": "unsupported_intent",
    "lowConfidence": "low_confidence",
    "invalidQuery": "invalid_query",
    "policyNotFound": "policy_not_found",
    "contextMissing": "context_missing"
  }
}